{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21
  },
  "configurePresets": [
    {
      "name": "base",
      "displayName": "Basic Config",
      "description": "Basic build using Ninja generator",
      "generator": "Ninja",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "cacheVariables": {
        "XdkEditionTarget": "260400"
      }
    },

    {
      "name": "x64",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": { "GDK_ARCH": "x64" },
      "hidden": true
    },
    {
      "name": "ARM64",
      "architecture": {
        "value": "arm64",
        "strategy": "external"
      },
      "cacheVariables": { "GDK_ARCH": "arm64" },
      "hidden": true
    },

    {
      "name": "Debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" },
      "hidden": true
    },
    {
      "name": "Release",
      "cacheVariables":
      {
          "CMAKE_BUILD_TYPE": "RelWithDebInfo",
          "CMAKE_INTERPROCEDURAL_OPTIMIZATION": true
      },
      "hidden": true
    },

    {
      "name": "OneCore",
      "cacheVariables": { "BUILD_USING_ONECORE": true },
      "hidden": true
    },

    {
      "name": "MSVC",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "cl.exe"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      }
    },
    {
      "name": "Clang",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang-cl.exe"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      }
    },
    {
      "name": "Clang-AArch64",
      "environment": {
        "CFLAGS": "--target=arm64-pc-windows-msvc",
        "CXXFLAGS": "--target=arm64-pc-windows-msvc"
      },
      "hidden": true
    },

    { "name": "x64-Debug"    , "description": "MSVC for x64 (Debug)", "inherits": [ "base", "x64", "Debug", "MSVC" ] },
    { "name": "x64-Release"  , "description": "MSVC for x64 (Release)", "inherits": [ "base", "x64", "Release", "MSVC" ] },

    { "name": "x64-Debug-OneCore"  , "description": "MSVC for x64 (Debug) Windows 10 only", "inherits": [ "base", "x64", "Debug", "OneCore", "MSVC" ] },
    { "name": "x64-Release-OneCore", "description": "MSVC for x64 (Release) Windows 10 only", "inherits": [ "base", "x64", "Release", "OneCore", "MSVC" ] },

    { "name": "x64-Debug-Clang"    , "description": "Clang/LLVM for x64 (Debug)", "inherits": [ "base", "x64", "Debug", "Clang" ] },
    { "name": "x64-Release-Clang"  , "description": "Clang/LLVM for x64 (Release)", "inherits": [ "base", "x64", "Release", "Clang" ] },

    { "name": "x64-Debug-OneCore-Clang"  , "description": "Clang/LLVM for x64 (Debug) Windows 10 only", "inherits": [ "base", "x64", "Debug", "OneCore", "Clang" ] },
    { "name": "x64-Release-OneCore-Clang", "description": "Clang/LLVM for x64 (Release) Windows 10 only", "inherits": [ "base", "x64", "Release", "OneCore", "Clang" ] },

    { "name": "arm64-Debug"    , "description": "MSVC for ARM64 (Debug)", "inherits": [ "base", "ARM64", "Debug", "MSVC" ] },
    { "name": "arm64-Release"  , "description": "MSVC for ARM64 (Release)", "inherits": [ "base", "ARM64", "Release", "MSVC" ] },

    { "name": "arm64-Debug-Clang"    , "description": "Clang/LLVM for ARM64 (Debug)", "inherits": [ "base", "ARM64", "Debug", "Clang", "Clang-AArch64" ] },
    { "name": "arm64-Release-Clang"  , "description": "Clang/LLVM for ARM64 (Release)", "inherits": [ "base", "ARM64", "Release", "Clang", "Clang-AArch64" ] }
  ]
}