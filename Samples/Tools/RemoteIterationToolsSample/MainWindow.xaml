<Window x:Class="RemoteIterationToolsSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Remote Deployment" Height="961" Width="752"
        Background="#FF1E1E24" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#FF2C2C34"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF4E9AF1"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0 4 0 12"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#33111111"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0 4 8 12"/>
            <Setter Property="Padding" Value="12 8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#333F51"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#444"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ArrowExpander" TargetType="Expander">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderToggle"
                                          Content="{TemplateBinding Header}"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <StackPanel Orientation="Horizontal" TextElement.Foreground="White">
                                                <TextBlock x:Name="Arrow" Text="▶" FontSize="12" VerticalAlignment="Center" Margin="0 0 8 0"/>
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpanderContent" Visibility="Collapsed" Margin="0 8 0 0"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpanderContent" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="200"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Remote Iteration Tools" FontSize="26" FontWeight="SemiBold"/>

            <!-- Inputs Card -->
            <Border Grid.Row="1" Background="{StaticResource CardBackground}" Padding="20" CornerRadius="10" Margin="0 20 0 16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.ColumnSpan="2" Grid.Row="0">
                        <TextBlock Text="Device" FontWeight="Bold" Margin="0 0 0 4"/>
                        <TextBox x:Name="DeviceIpTextBox" ToolTip="e.g. 192.168.1.25" Width="224" HorizontalAlignment="Left" AutomationProperties.Name="Device name or IP address"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0 8 0 0">
                        <TextBlock Text="Source Folder" FontWeight="Bold" Margin="0 0 0 4"/>
                        <DockPanel>
                            <TextBox x:Name="FolderPathTextBox" MinWidth="420" ToolTip="Type a path or use Browse to select a folder" Width="524" Height="40" AutomationProperties.Name="Source folder path"/>
                            <Button Content="Browse" Click="BrowseFolder_Click" DockPanel.Dock="Left" MinWidth="100" Height="40" Margin="10,0,0,10" HorizontalAlignment="Left" AutomationProperties.Name="Browse for source folder"/>
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0 8 0 0">
                        <TextBlock Text="Destination Folder" FontWeight="Bold" Margin="0 0 0 4"/>
                        <DockPanel>
                            <TextBox x:Name="DestinationPathTextBox" MinWidth="420" ToolTip="Remote destination relative to game root" Width="524" HorizontalAlignment="Left" AutomationProperties.Name="Destination folder path"/>
                        </DockPanel>
                    </StackPanel>

                    <Expander Grid.Row="3" Grid.ColumnSpan="2" Header="Advanced Options" IsExpanded="False" Margin="0 8 0 0" Foreground="White" Style="{StaticResource ArrowExpander}">
                        <StackPanel Margin="0 8 0 0">
                            <TextBlock Text="Include File Pattern" FontWeight="Bold" Margin="0 0 0 4" 
                   ToolTip="Includes files that match the exact specified names. Wildcard characters * and ? are supported. List of patterns can be separated by semicolon (;). Files with spaces in the name must be quoted. Default is everything is included."/>
                            <TextBox x:Name="IncludeFilePatternTextBox" MinWidth="420" Width="524" HorizontalAlignment="Left" AutomationProperties.Name="Include file pattern" 
                  ToolTip="Includes files that match the exact specified names. Wildcard characters * and ? are supported. List of patterns can be separated by semicolon (;). Files with spaces in the name must be quoted. Default is everything is included."/>

                            <TextBlock Text="Exclude File Pattern" FontWeight="Bold" Margin="0 0 0 4" 
                  ToolTip="Excludes files that match the exact specified names. Wildcard characters * and ? are supported. List of patterns can be separated by semicolon (;). Files with spaces in the name must be quoted. Default is empty (no excluded files)."/>
                            <TextBox x:Name="ExcludeFilePatternTextBox" MinWidth="420" Width="524" HorizontalAlignment="Left" AutomationProperties.Name="Exclude file pattern" 
                  ToolTip="Excludes files that match the exact specified names. Wildcard characters * and ? are supported. List of patterns can be separated by semicolon (;). Files with spaces in the name must be quoted. Default is empty (no excluded files)."/>

                            <TextBlock Text="Exclude Directory Pattern" FontWeight="Bold" Margin="0 0 0 4" 
                  ToolTip="Excludes directories that match the specified names and paths. Wildcard characters * and ? are supported. Default is empty, no excluded directories from being copied."/>
                            <TextBox x:Name="ExcludeDirPatternTextBox" MinWidth="420" Width="524" HorizontalAlignment="Left" AutomationProperties.Name="Exclude directory pattern" 
                  ToolTip="Excludes directories that match the specified names and paths. Wildcard characters * and ? are supported. Default is empty, no excluded directories from being copied."/>

                            <TextBlock Text="Include File Attributes" FontWeight="Bold" Margin="0 0 0 4" 
                  ToolTip="Include files for which any of the specified file attributes are set. Supported options are FILE_ATTRIBUTE_READONLY, FILE_ATTRIBUTE_ARCHIVE, FILE_ATTRIBUTE_SYSTEM, and FILE_ATTRIBUTE_HIDDEN. Default is 0 (All attributes are included)."/>
                            <TextBox x:Name="IncludeFileAttributesTextBox" MinWidth="420" Width="524" HorizontalAlignment="Left" AutomationProperties.Name="Include file attributes" 
                  ToolTip="Include files for which any of the specified file attributes are set. Supported options are FILE_ATTRIBUTE_READONLY, FILE_ATTRIBUTE_ARCHIVE, FILE_ATTRIBUTE_SYSTEM, and FILE_ATTRIBUTE_HIDDEN. Default is 0 (All attributes are included)."/>

                            <TextBlock Text="Exclude File Attributes" FontWeight="Bold" Margin="0 0 0 4" 
                  ToolTip="Exclude files for which any of the specified file attributes are set. Supported options are FILE_ATTRIBUTE_READONLY, FILE_ATTRIBUTE_ARCHIVE, FILE_ATTRIBUTE_SYSTEM, and FILE_ATTRIBUTE_HIDDEN. Default is 0 (no attributes excluded)."/>
                            <TextBox x:Name="ExcludeFileAttributesTextBox" MinWidth="420" Width="524" HorizontalAlignment="Left" AutomationProperties.Name="Exclude file attributes" 
                  ToolTip="Exclude files for which any of the specified file attributes are set. Supported options are FILE_ATTRIBUTE_READONLY, FILE_ATTRIBUTE_ARCHIVE, FILE_ATTRIBUTE_SYSTEM, and FILE_ATTRIBUTE_HIDDEN. Default is 0 (no attributes excluded)."/>
                        </StackPanel>
                    </Expander>

                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0 8 0 0" Orientation="Horizontal">
                        <Button Content="Deploy" MinWidth="120" Height="35" HorizontalAlignment="Left" Click="Deploy_Click" Grid.ColumnSpan="2" AutomationProperties.Name="Deploy build"/>
                        <Button Content="Cancel" MinWidth="120" Height="35" HorizontalAlignment="Left" Click="Cancel_Click" Grid.ColumnSpan="2" AutomationProperties.Name="Cancel deployment"/>
                    </StackPanel>

                    <StackPanel Grid.Row="5" Grid.Column="0" Margin="0 8 0 0" x:Name="ProgressPanel" Visibility="Visible" Grid.ColumnSpan="2">
                        <TextBlock x:Name="ProgressStatusText" Text="Deploy Progress" FontSize="12" Margin="0 0 0 4" Foreground="#AAAAAA"/>
                        <ProgressBar x:Name="DeploymentProgressBar" HorizontalAlignment="Stretch" Height="20" Minimum="0" Maximum="100" Value="0" Background="#222" Foreground="{StaticResource AccentBrush}" BorderBrush="#555" BorderThickness="1" AutomationProperties.Name="Deployment progress"/>
                        <TextBlock x:Name="ProgressPercentText" Text="0%" FontSize="11" Margin="0 4 25 0" Foreground="#AAAAAA" HorizontalAlignment="Right"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.Column="0" Margin="0 8 0 0" >
                        <TextBlock Text="Executable to launch" FontWeight="Bold" Margin="0 0 0 4"/>
                        <DockPanel>
                            <TextBox x:Name="ExecutablePathTextBox" MinWidth="420" ToolTip="Remote path relative to game root" Width="524" HorizontalAlignment="Left" AutomationProperties.Name="Executable path"/>
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="7" Grid.Column="0" Margin="0 8 0 0" Orientation="Horizontal">
                        <Button Content="Launch" MinWidth="120" Height="35" HorizontalAlignment="Left" Click="Launch_Click" Grid.ColumnSpan="2" AutomationProperties.Name="Launch game"/>
                        <Button Content="Launch Suspended" MinWidth="120" Height="35" HorizontalAlignment="Left" Click="LaunchSuspended_Click" Grid.ColumnSpan="2" AutomationProperties.Name="Launch game suspended"/>
                        <Button Content="Resume" MinWidth="120" Height="35" HorizontalAlignment="Left" Click="Resume_Click" Grid.ColumnSpan="2" AutomationProperties.Name="Resume game"/>
                        <Button Content="Terminate" MinWidth="120" Height="35" HorizontalAlignment="Left" Click="Terminate_Click" Grid.ColumnSpan="2" AutomationProperties.Name="Terminate game"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Output Area -->
            <Border Grid.Row="2" Background="{StaticResource CardBackground}" Padding="16" CornerRadius="10" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Command Output" FontWeight="Bold" Margin="0 0 0 8"/>

                    <TextBox x:Name="OutputTextBox" Grid.Row="1" MaxHeight="300" TextWrapping="Wrap" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#00111111" BorderThickness="0" FontFamily="Consolas" Foreground="#DDDDDD" AutomationProperties.Name="Command output"/>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
